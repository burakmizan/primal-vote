{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "primal-vote",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Primal Vote: New Post",
        "description": "Create a new Primal Vote post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      },
      {
        "label": "Primal Vote: Advance Day",
        "description": "Manually run the daily mutation job",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/advance-day"
      },
      {
        "label": "Primal Vote: Trigger Crisis",
        "description": "Start a crisis event (defaults to ice_age)",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/trigger-crisis"
      },
      {
        "label": "Primal Vote: Close Vote",
        "description": "Close the active vote early",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/close-vote"
      },
      {
        "label": "Primal Vote: Load Demo State",
        "description": "Load ZORGATH seeded state for testing",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/load-demo-state"
      },
      {
        "label": "Primal Vote: Set Vote Window 1h",
        "description": "Shorten the current vote window to 1 hour",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/set-vote-window-1h"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "permissions": ["reddit", "redis", "http", "scheduler"],
  "scheduledJobs": [
    {
      "name": "daily-mutation-job",
      "cron": "0 0 * * *",
      "endpoint": "/internal/triggers/daily-mutation-job"
    }
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "primal_vote_dev"
  }
}
